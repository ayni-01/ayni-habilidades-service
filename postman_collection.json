        ],
        "url": {
          "raw": "{{BASE_HABILIDADES}}/api/v1/insignias",
          "host": [
            "{{BASE_HABILIDADES}}"
          ],
          "path": [
            "api",
            "v1",
            "insignias"
          ]
        },
        "body": {
